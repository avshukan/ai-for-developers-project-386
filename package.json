{
  "name": "call-booking-api-contract",
  "version": "0.1.0",
  "private": true,
  "description": "TypeSpec API contract for the Call Booking learning project.",
  "type": "module",
  "scripts": {
    "typespec": "tsp compile api --no-emit",
    "openapi": "tsp compile api",
    "check": "npm run typespec && npm run openapi",
    "mock": "npx --yes @stoplight/prism-cli mock openapi/openapi.yaml"
  },
  "devDependencies": {
    "@typespec/compiler": "1.13.0",
    "@typespec/http": "1.13.0",
    "@typespec/openapi3": "1.13.0"
  },
  "engines": {
    "node": ">=20"
  }
}
