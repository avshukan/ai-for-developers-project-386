# Vite mode used by the Playwright integration tests (run with `vite --mode e2e`).
# Points the SPA at the local Go backend started by Playwright's webServer,
# instead of the Prism mock default. Tracked in git on purpose (no secrets here).
# See e2e/playwright.config.ts and docs/adr/0003-integration-tests-playwright.md.
VITE_API_BASE_URL=http://localhost:8080
